# === Workspace-level ignores ===

# Unrelated cloned repo (Microsoft VS Code source)
/vscode/

# macOS / OS junk
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# IDE / editor
.idea/
.vscode/
*.iml
*.ipr
*.iws
*.swp
*.swo
*~

# Logs / crash reports
*.log
crash.log
npm-debug.log*

# Belt-and-suspenders Flutter ignores (project-level .gitignore already handles these)
**/.dart_tool/
**/.flutter-plugins
**/.flutter-plugins-dependencies
**/.packages
**/build/
**/.gradle/

# Android signing / local config (never commit secrets)
**/android/key.properties
**/android/app/keystore.jks
**/android/app/*.jks
**/android/app/*.keystore
**/android/local.properties

# Firebase / Google services configs (NEVER commit — they leak API keys)
**/google-services.json
**/GoogleService-Info.plist
**/firebase_options.dart
**/firebase_app_id_file.json
**/firebase-app-id-file.json

# App-level secrets file (each project should have its own; copy from secrets.example.dart)
**/lib/Services/secrets.dart
**/lib/secrets.dart

# iOS / macOS build artifacts
**/ios/Pods/
**/macos/Pods/
**/ios/Flutter/ephemeral/
**/macos/Flutter/ephemeral/
**/Podfile.lock.backup
**/*.xcuserdata/
**/xcuserdata/

# Linux / Windows ephemeral
**/linux/flutter/ephemeral/
**/windows/flutter/ephemeral/

# Built outputs
*.apk
*.aab
*.ipa
